# Databricks Connection
DATABRICKS_PROFILE=DEFAULT
DATABRICKS_CLUSTER_ID=your-cluster-id

# Remote workspace path where validation scripts are uploaded
DATABRICKS_WORKSPACE_DIR=/Workspace/Users/you@example.com/graph_validation

# Neo4j Credentials
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

# Unity Catalog Volume path containing lab data files
DATABRICKS_VOLUME_PATH=/Volumes/catalog/schema/volume

# Supervisor Agent endpoint name (Lab 6 → Lab 7)
# Note: Databricks uses the "mas-" prefix in endpoint names (Multi-Agent Supervisor)
SUPERVISOR_AGENT_ENDPOINT=mas-3ae5a347-endpoint

# Embedding model endpoint (for generate_embeddings.py, optional)
EMBEDDING_ENDPOINT=databricks-gte-large-en

# Graph enrichment pipeline control (run_lab7.py)
# ANALYSIS_ONLY=true stops after DSPy analysis (skips resolution + write-back)
ANALYSIS_ONLY=false
# DRY_RUN=true previews Cypher statements without executing them
DRY_RUN=true

