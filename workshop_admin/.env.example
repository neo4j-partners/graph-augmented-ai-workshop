# Databricks Connection
DATABRICKS_PROFILE=DEFAULT
DATABRICKS_CLUSTER_ID=your-cluster-id

# Remote workspace path where scripts are uploaded
DATABRICKS_WORKSPACE_DIR=/Workspace/Users/you@example.com/workshop_admin

# Unity Catalog Volume path containing HTML files and embedding output
DATABRICKS_VOLUME_PATH=/Volumes/catalog/schema/volume

# Embedding model endpoint (optional, defaults to databricks-gte-large-en)
EMBEDDING_ENDPOINT=databricks-gte-large-en
