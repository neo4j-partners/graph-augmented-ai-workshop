# Databricks Connection
DATABRICKS_PROFILE=DEFAULT
DATABRICKS_CLUSTER_ID=your-cluster-id

# Remote workspace path where scripts are uploaded
WORKSPACE_DIR=/Workspace/Users/you@example.com/lab_setup

# Neo4j Credentials (needed by generate_embeddings if writing to Neo4j)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

# Unity Catalog Volume path containing lab data files
VOLUME_PATH=/Volumes/catalog/schema/volume

# Embedding model endpoint (optional, defaults to databricks-gte-large-en)
EMBEDDING_ENDPOINT=databricks-gte-large-en
